{
	"name": "wireguard-proxy-monorepo",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev:webapp": "pnpm --filter @wireguard-proxy/webapp dev",
		"build:webapp": "pnpm --filter @wireguard-proxy/webapp build",
		"build:core": "pnpm --filter @wireguard-proxy/core build",
		"build:client": "pnpm --filter @wireguard-proxy/client build",
		"build": "pnpm -r run build"
	},
	"devDependencies": {
		"release-it": "^19.2.4"
	}
}
